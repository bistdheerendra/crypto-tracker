# Copy to .env (or .env.local for Next.js) and fill in real values.
# Without a real DATABASE_URL, verdicts stay in process memory (dev fallback).

# Supabase — transaction pooler for app runtime (port 6543)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase — session pooler for Prisma migrations (port 5432)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Optional — cron auth for /api/cron/* routes
# CRON_SECRET=

# Optional — real ETF net flow data via SoSoValue Demo API (falls back to Yahoo proxy)
# SOSOVALUE_API_KEY=

# Optional — durable radar / alert-prefs cache via Upstash Redis free tier (falls back to in-memory)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional — Copilot LLM (prefer Gemini free tier; Anthropic is paid fallback)
# Get free key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional — Telegram alerts (verdicts + radar spikes)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
