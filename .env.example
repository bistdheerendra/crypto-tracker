# Copy to .env (or .env.local for Next.js) and fill in real values.
# Without a real DATABASE_URL, verdicts stay in process memory (dev fallback).

# Supabase — transaction pooler for app runtime (port 6543)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase — session pooler for Prisma migrations (port 5432)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Optional — cron auth for /api/cron/resolve-verdicts
# CRON_SECRET=

# Optional — future features
# ANTHROPIC_API_KEY=
# TELEGRAM_BOT_TOKEN=
