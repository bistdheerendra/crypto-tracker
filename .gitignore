# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

/src/generated/prisma

# generated ML datasets
/ml/data/

# trained model artifacts (keep ONNX + sidecars for Vercel Node inference)
/ml/models/*
!/ml/models/baseline_classifier.onnx
!/ml/models/feature_medians.json
!/ml/models/feature_columns.json
!/ml/models/.gitkeep

# onnxruntime-web WASM binaries (required for Vercel inference)
!/ml/ort-wasm/
